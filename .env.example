# ══════════════════════════════════════════════════════
#  ORAK UNIVERSE — Variables de Entorno
#  Copia este archivo como .env y rellena los valores
#  NUNCA commitees .env a git
# ══════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────
APP_NAME=ORAK Universe API
APP_VERSION=3.0.0
DEBUG=false
PORT=8000

# ── Supabase ──────────────────────────────────────────
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu-service-role-key-aqui
SUPABASE_ANON_KEY=tu-anon-key-aqui

# ── CORS ──────────────────────────────────────────────
# Separar múltiples orígenes con comas
# En desarrollo: *
# En producción: https://tu-dominio.com,https://www.tu-dominio.com
CORS_ORIGINS=*

# ── Railway ───────────────────────────────────────────
# Railway inyecta esta variable automáticamente
# RAILWAY_PUBLIC_DOMAIN=tu-app.railway.app

# ── ngrok (desarrollo local) ──────────────────────────
# NGROK_URL=https://xxxx.ngrok-free.app

# ── Auth futura ───────────────────────────────────────
JWT_SECRET=cambia-esto-en-produccion-usa-openssl-rand-hex-32

# ── IA futura ─────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
